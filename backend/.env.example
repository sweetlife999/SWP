# su_app is the least-privilege DML-only role (migrations/0010_app_role.sql),
# not the schema-owning su role — set its password via APP_DB_PASSWORD when
# running the migrate service.
DATABASE_URL=postgresql://su_app:change-this-app-db-password@db:5432/su_portal
ADMIN_PASSWORD=change-this-to-a-strong-password
JWT_SECRET=replace-with-a-long-random-secret
TOKEN_EXPIRE_HOURS=168
CORS_ORIGINS=http://localhost:3000,https://su.fblrkus.ru
DEBUG=false
